   \"test\": 200\n","        }\n","    }\n","}\n","```"]},{"cell_type":"markdown","metadata":{"id":"d80ec615"},"source":["Пример содержимого файла `models/final/{experiment_name}.json` с добавленными списками каналов:\n","```json\n","{\n","  \"experiment_name\": \"unet_finetuning_dataset_patches_PS_14_bands_excluding_blue_01\",\n","  \"best_epoch\": 3,\n","  \"best_val_iou\": 0.8017978668212891,\n","  \"num_classes\": 2,\n","  \"in_channels\": 14,\n","  \"ps_bands\": [\n","    \"B01\",\n","    \"B02\",\n","    \"B03\",\n","    \"B04\"\n","  ],\n","  \"s2_bands\": [\n","    \"B02\",\n","    \"B03\",\n","    \"B04\",\n","    \"B05\",\n","    \"B06\",\n","    \"B07\",\n","    \"B08\",\n","    \"B8A\",\n","    \"B11\",\n","    \"B12\"\n","  ],\n","  \"ls_bands\": [\n","    \"B1\",\n","    \"B2\",\n","    \"B3\",\n","    \"B4\",\n","    \"B5\",\n","    \"B6\",\n","    \"B7\"\n","  ]\n","}\n","```"]}],"metadata":{"accelerator":"GPU","colab":{"gpuType":"T4","provenance":[{"file_id":"13AzWsnNwbQ3uV9LgBoyhlA-v4SS1FYPP","timestamp":1779290474860}],"collapsed_sections":["PiEmNJv7wwrU"]},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}