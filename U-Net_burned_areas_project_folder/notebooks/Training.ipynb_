e>35</title>\n<polygon fill=\"#c1ffc1\" stroke=\"transparent\" points=\"410,-266 149,-266 149,-224 410,-224 410,-266\"/>\n<polygon fill=\"none\" stroke=\"black\" points=\"149.5,-224 149.5,-266 226.5,-266 226.5,-224 149.5,-224\"/>\n<text text-anchor=\"start\" x=\"154.5\" y=\"-248\" font-family=\"Linux libertine\" font-size=\"10.00\">BatchNorm2d</text>\n<text text-anchor=\"start\" x=\"166.5\" y=\"-237\" font-family=\"Linux libertine\" font-size=\"10.00\">depth:3</text>\n<polygon fill=\"none\" stroke=\"black\" points=\"226.5,-245 226.5,-266 285.5,-266 285.5,-245 226.5,-245\"/>\n<text text-anchor=\"start\" x=\"237.5\" y=\"-253\" font-family=\"Linux libertine\" font-size=\"10.00\">input:</text>\n<polygon fill=\"none\" stroke=\"black\" points=\"285.5,-245 285.5,-266 410.5,-266 410.5,-245 285.5,-245\"/>\n<text text-anchor=\"start\" x=\"290.5\" y=\"-253\" font-family=\"Linux libertine\" font-size=\"10.00\">(64, 32, 128, 128) </text>\n<polygon fill=\"none\" stroke=\"black\" points=\"226.5,-224 226.5,-245 285.5,-245 285.5,-224 226.5,-224\"/>\n<text text-anchor=\"start\" x=\"231.5\" y=\"-232\" font-family=\"Linux libertine\" font-size=\"10.00\">output: </text>\n<polygon fill=\"none\" stroke=\"black\" points=\"285.5,-224 285.5,-245 410.5,-245 410.5,-224 285.5,-224\"/>\n<text text-anchor=\"start\" x=\"290.5\" y=\"-232\" font-family=\"Linux libertine\" font-size=\"10.00\">(64, 32, 128, 128) </text>\n</g>\n<!-- 34&#45;&gt;35 -->\n<g id=\"edge37\" class=\"edge\">\n<title>34&#45;&gt;35</title>\n<path fill=\"none\" stroke=\"black\" d=\"M279.5,-301.63C279.5,-293.82 279.5,-284.73 279.5,-276.18\"/>\n<polygon fill=\"black\" stroke=\"black\" points=\"283,-276.16 279.5,-266.16 276,-276.16 283,-276.16\"/>\n</g>\n<!-- 36 -->\n<g id=\"node37\" class=\"node\">\n<title>36</title>\n<polygon fill=\"#c1ffc1\" stroke=\"transparent\" points=\"398,-188 161,-188 161,-146 398,-146 398,-188\"/>\n<polygon fill=\"none\" stroke=\"black\" points=\"161.5,-146 161.5,-188 214.5,-188 214.5,-146 161.5,-146\"/>\n<text text-anchor=\"start\" x=\"175.5\" y=\"-170\" font-family=\"Linux libertine\" font-size=\"10.00\">ReLU</text>\n<text text-anchor=\"start\" x=\"166.5\" y=\"-159\" font-family=\"Linux libertine\" font-size=\"10.00\">depth:3</text>\n<polygon fill=\"none\" stroke=\"black\" points=\"214.5,-167 214.5,-188 273.5,-188 273.5,-167 214.5,-167\"/>\n<text text-anchor=\"start\" x=\"225.5\" y=\"-175\" font-family=\"Linux libertine\" font-size=\"10.00\">input:</text>\n<polygon fill=\"none\" stroke=\"black\" points=\"273.5,-167 273.5,-188 398.5,-188 398.5,-167 273.5,-167\"/>\n<text text-anchor=\"start\" x=\"278.5\" y=\"-175\" font-family=\"Linux libertine\" font-size=\"10.00\">(64, 32, 128, 128) </text>\n<polygon fill=\"none\" stroke=\"black\" points=\"214.5,-146 214.5,-167 273.5,-167 273.5,-146 214.5,-146\"/>\n<text text-anchor=\"start\" x=\"219.5\" y=\"-154\" font-family=\"Linux libertine\" font-size=\"10.00\">output: </text>\n<polygon fill=\"none\" stroke=\"black\" points=\"273.5,-146 273.5,-167 398.5,-167 398.5,-146 273.5,-146\"/>\n<text text-anchor=\"start\" x=\"278.5\" y=\"-154\" font-family=\"Linux libertine\" font-size=\"10.00\">(64, 32, 128, 128) </text>\n</g>\n<!-- 35&#45;&gt;36 -->\n<g id=\"edge38\" class=\"edge\">\n<title>35&#45;&gt;36</title>\n<path fill=\"none\" stroke=\"black\" d=\"M279.5,-223.63C279.5,-215.82 279.5,-206.73 279.5,-198.18\"/>\n<polygon fill=\"black\" stroke=\"black\" points=\"283,-198.16 279.5,-188.16 276,-198.16 283,-198.16\"/>\n</g>\n<!-- 37 -->\n<g id=\"node38\" class=\"node\">\n<title>37</title>\n<polygon fill=\"#c1ffc1\" stroke=\"transparent\" points=\"398,-110 161,-110 161,-68 398,-68 398,-110\"/>\n<polygon fill=\"none\" stroke=\"black\" points=\"161.5,-68 161.5,-110 214.5,-110 214.5,-68 161.5,-68\"/>\n<text text-anchor=\"start\" x=\"169.5\" y=\"-92\" font-family=\"Linux libertine\" font-size=\"10.00\">Conv2d</text>\n<text text-anchor=\"start\" x=\"166.5\" y=\"-81\" font-family=\"Linux libertine\" font-size=\"10.00\">depth:1</text>\n<polygon fill=\"none\" stroke=\"black\" points=\"214.5,-89 214.5,-110 273.5,-110 273.5,-89 214.5,-89\"/>\n<text text-anchor=\"start\" x=\"225.5\" y=\"-97\" font-family=\"Linux libertine\" font-size=\"10.00\">input:</text>\n<polygon fill=\"none\" stroke=\"black\" points=\"273.5,-89 273.5,-110 398.5,-110 398.5,-89 273.5,-89\"/>\n<text text-anchor=\"start\" x=\"278.5\" y=\"-97\" font-family=\"Linux libertine\" font-size=\"10.00\">(64, 32, 128, 128) </text>\n<polygon fill=\"none\" stroke=\"black\" points=\"214.5,-68 214.5,-89 273.5,-89 273.5,-68 214.5,-68\"/>\n<text text-anchor=\"start\" x=\"219.5\" y=\"-76\" font-family=\"Linux libertine\" font-size=\"10.00\">output: </text>\n<polygon fill=\"none\" stroke=\"black\" points=\"273.5,-68 273.5,-89 398.5,-89 398.5,-68 273.5,-68\"/>\n<text text-anchor=\"start\" x=\"281.5\" y=\"-76\" font-family=\"Linux libertine\" font-size=\"10.00\">(64, 2, 128, 128) </text>\n</g>\n<!-- 36&#45;&gt;37 -->\n<g id=\"edge39\" class=\"edge\">\n<title>36&#45;&gt;37</title>\n<path fill=\"none\" stroke=\"black\" d=\"M279.5,-145.63C279.5,-137.82 279.5,-128.73 279.5,-120.18\"/>\n<polygon fill=\"black\" stroke=\"black\" points=\"283,-120.16 279.5,-110.16 276,-120.16 283,-120.16\"/>\n</g>\n<!-- 38 -->\n<g id=\"node39\" class=\"node\">\n<title>38</title>\n<polygon fill=\"lightyellow\" stroke=\"transparent\" points=\"380.5,-32 178.5,-32 178.5,0 380.5,0 380.5,-32\"/>\n<polygon fill=\"none\" stroke=\"black\" points=\"178.5,0 178.5,-32 267.5,-32 267.5,0 178.5,0\"/>\n<text text-anchor=\"start\" x=\"183.5\" y=\"-19\" font-family=\"Linux libertine\" font-size=\"10.00\">output&#45;tensor</text>\n<text text-anchor=\"start\" x=\"201.5\" y=\"-8\" font-family=\"Linux libertine\" font-size=\"10.00\">depth:0</text>\n<polygon fill=\"none\" stroke=\"black\" points=\"267.5,0 267.5,-32 380.5,-32 380.5,0 267.5,0\"/>\n<text text-anchor=\"start\" x=\"272.5\" y=\"-13.5\" font-family=\"Linux libertine\" font-size=\"10.00\">(64, 2, 128, 128)</text>\n</g>\n<!-- 37&#45;&gt;38 -->\n<g id=\"edge40\" class=\"edge\">\n<title>37&#45;&gt;38</title>\n<path fill=\"none\" stroke=\"black\" d=\"M279.5,-67.84C279.5,-59.89 279.5,-50.66 279.5,-42.26\"/>\n<polygon fill=\"black\" stroke=\"black\" points=\"283,-42.24 279.5,-32.24 276,-42.24 283,-42.24\"/>\n</g>\n</g>\n</svg>\n","text/plain":["<graphviz.graphs.Digraph at 0x7eccc6cf5c70>"]},"metadata":{},"execution_count":12}],"source":["# Create UNet model and move to device\n","model = UNet(in_channels=INPUT_CHANNELS, num_classes=NUM_CLASSES).to(device)\n","\n","# Display model summary\n","print(\"UNet Model Summary:\")\n","print(\"=\"*60)\n","summary(model, input_size=(INPUT_CHANNELS, INPUT_SIZE[0], INPUT_SIZE[1]))\n","print(\"=\"*60)\n","model_graph = draw_graph(model, input_size=(BATCH_SIZE,)+(INPUT_CHANNELS,)+INPUT_SIZE, expand_nested=True, depth=3)\n","model_graph.visual_graph"]},{"cell_type":"markdown","metadata":{"id":"ibSiyp8XxNu0"},"source":["## 🚀 **Train UNet from Scratch**"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"1AIx_V0VxjKVQ1gTTyzceLTQoJfbjfmL9"},"executionInfo":{"elapsed":2900360,"status":"ok","timestamp":1780851929439,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"},"user_tz":-120},"id":"QGD_W1XCodJU","outputId":"40bb0cb8-6900-42d4-9e22-24248cd61a13"},"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}],"source":["%%time\n","# Setup TensorBoard writer\n","\n","writer = SummaryWriter(f\"./{logs_dir}/{experiment_name}\")\n","Path(f\"models/checkpoints/{experiment_name}\").mkdir(parents=True, exist_ok=True)\n","\n","\n","# Train the model\n","model, history = train_segmentation_model(\n","    model=model,\n","    train_loader=train_loader,\n","    val_dataset=val_dataset,\n","    val_loader=val_loader,\n","    meta=meta,\n","    epochs=EPOCHS,\n","    learning_rate=LEARNING_RATE,\n","    patience=PATIENCE,\n","    num_classes=NUM_CLASSES,\n","    device=device,\n","    writer=writer,\n","    experiment_name=experiment_name,\n","    visualize_every=5,\n",")\n","\n","# Display final validation IoU\n","final_val_iou = round(max(history['val_mean_iou']) * 100, 2)\n","print(f'\\nFinal validation Mean IoU: {final_val_iou}%')"]},{"cell_type":"markdown","metadata":{"id":"5fmc03TMxMTs"},"source":["## 📈 **Plot Training History**"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":383},"executionInfo":{"elapsed":907,"status":"ok","timestamp":1780851930344,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"},"user_tz":-120},"id":"GZngft86o_IX","outputId":"c595c0e2-eb9f-4820-ccc2-b67dd7924326"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# Plot training curves for loss, accuracy, and Mean IoU\n","fig, axes = plt.subplots(1, 3, figsize=(18, 4))\n","\n","# Loss plot\n","axes[0].plot(history['loss'], label='Train', alpha=0.8, color='#ff7f0e', linewidth=2)\n","axes[0].plot(history['val_loss'], label='Val', alpha=0.9, color='#5a9aa5', linewidth=2)\n","axes[0].set_title('Cross-Entropy Loss', fontsize=14, fontweight='bold')\n","axes[0].set_xlabel('Epoch')\n","axes[0].set_ylabel('Loss')\n","axes[0].legend()\n","axes[0].grid(alpha=0.3)\n","\n","# Accuracy plot\n","axes[1].plot(history['accuracy'], label='Train', alpha=0.8, color='#ff7f0e', linewidth=2)\n","axes[1].plot(history['val_accuracy'], label='Val', alpha=0.9, color='#5a9aa5', linewidth=2)\n","axes[1].set_title('Pixel Accuracy', fontsize=14, fontweight='bold')\n","axes[1].set_xlabel('Epoch')\n","axes[1].set_ylabel('Accuracy')\n","axes[1].legend()\n","axes[1].grid(alpha=0.3)\n","\n","# Mean IoU plot\n","axes[2].plot(history['mean_iou'], label='Train', alpha=0.8, color='#ff7f0e', linewidth=2)\n","axes[2].plot(history['val_mean_iou'], label='Val', alpha=0.9, color='#5a9aa5', linewidth=2)\n","axes[2].set_title('Mean Intersection over Union', fontsize=14, fontweight='bold')\n","axes[2].set_xlabel('Epoch')\n","axes[2].set_ylabel('Mean IoU')\n","axes[2].legend()\n","axes[2].grid(alpha=0.3)\n","\n","plt.tight_layout()\n","# plt.savefig(f\"/content/drive/MyDrive/{experiment_name}_training_curves.png\", dpi=150, bbox_inches='tight')\n","plt.savefig(f\"experiments/{experiment_name}/training_curves.png\")\n","plt.show()"]},{"cell_type":"markdown","metadata":{"id":"BKBA8VDtxafl"},"source":["## 🧪 **Test Set Evaluation**"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":20,"status":"ok","timestamp":1780851930372,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"},"user_tz":-120},"id":"J6V0TJSMxZ1t","outputId":"99839fcb-a4a2-412b-d431-9712866684ab"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Creating test dataset...\n","Test dataset size: 400\n","Test batches: 7\n"]}],"source":["print(\"\\nCreating test dataset...\")\n","\n","test_dataset = NPYSegmentationDataset(\n","    root         = OUT_DIR,\n","    split        = \"test\",\n","    augmentation = False\n",")\n","\n","test_loader = DataLoader(\n","    test_dataset,\n","    batch_size  = BATCH_SIZE,\n","    shuffle     = False,\n","    num_workers = NUM_WORKERS,\n","    pin_memory  = True\n",")\n","\n","print(f\"Test dataset size: {len(test_dataset)}\")\n","print(f\"Test batches: {len(test_loader)}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":12,"status":"ok","timestamp":1780851930386,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"},"user_tz":-120},"id":"EVG3lqfuxb0p","outputId":"013ec11d-9afb-450a-c474-70942fca991e"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Loaded best model from: models/final/unet_dataset_PS_SENT_432_682_Ayman_best.pt\n"]}],"source":["best_model_path = f\"models/final/{experiment_name}_best.pt\"\n","\n","# Load the checkpoint dictionary\n","checkpoint = torch.load(best_model_path, map_location=torch.device('cpu'))\n","\n","# Extract the model's state_dict from the checkpoint\n","model.load_state_dict(checkpoint['model_state_dict'])\n","model.eval()\n","\n","print(f\"\\nLoaded best model from: {best_model_path}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":4818,"status":"ok","timestamp":1780851935206,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"},"user_tz":-120},"id":"FjdZznRmxda0","outputId":"f0e97275-ff57-4e29-d9f1-1786762cbee6"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Evaluating UNet from scratch on test set...\n","\n","============================================================\n","TEST RESULTS - UNet from Scratch\n","============================================================\n","Test Loss:        nan\n","Test Accuracy:    0.9662\n","Test Mean IoU:    0.9702\n","============================================================\n","Test results saved to experiments/unet_dataset_PS_SENT_432_682_Ayman/test_results.txt\n"]}],"source":["# Evaluate on test set using torchmetrics\n","print(\"\\nEvaluating UNet from scratch on test set...\")\n","\n","# Setup metrics\n","criterion = nn.CrossEntropyLoss(ignore_index=255)\n","test_iou_metric = torchmetrics.JaccardIndex(\n","    task='multiclass',\n","    num_classes=NUM_CLASSES,\n","    ignore_index=255,\n","    average='weighted'\n",").to(device)\n","\n","test_iou_per_class = torchmetrics.JaccardIndex(\n","    task='multiclass',\n","    num_classes=NUM_CLASSES,\n","    ignore_index=255,\n","    average='none'\n",").to(device)\n","\n","test_loss = 0.0\n","test_correct = 0\n","test_total = 0\n","\n","model.eval()\n","with torch.no_grad():\n","    for batch_images, batch_labels in test_loader:\n","        batch_images = batch_images.to(device)\n","        batch_labels = batch_labels.to(device)\n","\n","        # Forward pass\n","        outputs = model(batch_images)\n","        loss = criterion(outputs, batch_labels)\n","\n","        # Accumulate metrics\n","        test_loss += loss.item() * batch_images.size(0)\n","        preds = outputs.argmax(dim=1)\n","        test_correct += (preds == batch_labels).sum().item()\n","        test_total += batch_labels.numel()\n","\n","        # Update IoU metrics\n","        test_iou_metric.update(preds, batch_labels)\n","        test_iou_per_class.update(preds, batch_labels)\n","\n","# Compute final test metrics\n","test_loss = test_loss / len(test_loader.dataset)\n","test_acc = test_correct / test_total\n","test_mean_iou = test_iou_metric.compute().item()\n","test_iou_classes = test_iou_per_class.compute()\n","\n","print(\"\\n\" + \"=\"*60)\n","print(\"TEST RESULTS - UNet from Scratch\")\n","print(\"=\"*60)\n","print(f\"Test Loss:        {test_loss:.4f}\")\n","print(f\"Test Accuracy:    {test_acc:.4f}\")\n","print(f\"Test Mean IoU:    {test_mean_iou:.4f}\")\n","print(\"=\"*60)\n","\n","# Save test results to a file\n","results_filename = f\"experiments/{experiment_name}/test_results.txt\"\n","with open(results_filename, 'w') as f:\n","    f.write(f\"Test Loss: {test_loss:.4f}\\n\")\n","    f.write(f\"Test Accuracy: {test_acc:.4f}\\n\")\n","    f.write(f\"Test Mean IoU: {test_mean_iou:.4f}\\n\")\n","print(f\"Test results saved to {results_filename}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":7,"status":"ok","timestamp":1780851935215,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"},"user_tz":-120},"id":"qR8xfBL_zV0c","outputId":"ba4b31bb-2cd6-438a-a8c3-80337c4e1d37"},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Per-class IoU Analysis (using torchmetrics):\n","============================================================\n","Unburned            : 0.9812\n","Burned              : 0.9273\n","============================================================\n","Per-class IoU results appended to experiments/unet_dataset_PS_SENT_432_682_Ayman/test_results.txt\n"]}],"source":["class_names = {\n","    0: 'Unburned',\n","    1: 'Burned',\n","    255: 'Unmapped',\n","}\n","\n","# Display per-class IoU using torchmetrics results\n","print(\"\\nPer-class IoU Analysis (using torchmetrics):\")\n","print(\"=\"*60)\n","\n","per_class_iou = []\n","results_filename = f\"experiments/{experiment_name}/test_results.txt\"\n","with open(results_filename, 'a') as f: # Open in append mode\n","    f.write(\"\\nPer-class IoU Analysis:\\n\")\n","    for c in range(NUM_CLASSES):\n","        if c == 255:  # Skip background\n","            continue\n","        iou_value = test_iou_classes[c].item()\n","        class_name = class_names.get(c, f'Class {c}')\n","        per_class_iou.append((class_name, iou_value))\n","        print(f\"{class_name:20s}: {iou_value:.4f}\")\n","        f.write(f\"{class_name:20s}: {iou_value:.4f}\\n\")\n","\n","print(\"=\"*60)\n","print(f\"Per-class IoU results appended to {results_filename}\")"]},{"cell_type":"markdown","metadata":{"id":"6eE9jv8BxjRZ"},"source":["## 👁️ **Visualise Test Predictions**"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"elapsed":8506,"status":"ok","timestamp":1780851943738,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"},"user_tz":-120},"id":"ytI-9AM2xksH","outputId":"6cdb2e45-bbfd-47c1-a325-bdf91b2bb194"},"outputs":[{"output_type":"stream","name":"stdout","text":["Visualising test predictions:\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["print(\"Visualising test predictions:\")\n","plot_triptychs_from_loader(test_loader, model, num_samples=5, device=device, experiment_name=experiment_name)"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"867122c8","executionInfo":{"status":"ok","timestamp":1780851946134,"user_tz":-120,"elapsed":2398,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"}},"outputId":"4e88bb1b-cfc9-4a70-897e-e8cdcddfa882"},"source":["print(\"Visualising test predictions with selected samples:\")\n","plot_triptychs_from_loader_with_selection(test_dataset, model, num_samples=5, device=device, experiment_name=experiment_name)"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Visualising test predictions with selected samples:\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","metadata":{"id":"N-BwB83BFbw5"},"source":["## 👁️ **Visualise Pre-Argmax Output Maps**"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"elapsed":5189,"status":"ok","timestamp":1780851951327,"user":{"displayName":"Evgenii Miasnikov","userId":"16558642990374440926"},"user_tz":-120},"id":"NG95DxGhE8WG","outputId":"2a391528-9316-498f-c431-d7966533626d"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1800x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","\n"]}],"source":["plot_layer_outputs_from_loader(test_loader, model, num_samples=5, device=device, experiment_name=experiment_name)"]},{"cell_type":"markdown","metadata":{"id":"f2486e6f"},"source":["## Resources\n","\n","This notebook utilizes image patches generated in a previous step, either from the `Patch_creation` or `Patch_merging` notebooks. These patches serve as the input for training the U-Net model."]},{"cell_type":"markdown","source":["##### Contributors:\n","- **Evgenii Miasnikov**: evgenii.miasnikov@mail.polimi.it\n","- **Ayman Mutasim Alfadul Abdelgadir**: aymanmutasim@mail.polimi.it\n","- **Eugenio Lomurno**: eugenio.lomurno@polimi.it\n","- **Alberto Archetti**: alberto.archetti@polimi.